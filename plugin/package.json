{
  "name": "ossmconsole",
  "version": "2.29.0",
  "description": "OpenShift Service Mesh Console Plugin for Kiali.",
  "keywords": [
    "istio service mesh",
    "kiali",
    "monitoring",
    "observability",
    "openshift"
  ],
  "private": true,
  "license": "Apache-2.0",
  "author": "Red Hat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiali/openshift-servicemesh-plugin.git"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && sh -ac '. ./.env; NODE_ENV=production yarn ts-node node_modules/.bin/webpack'",
    "build:dev": "yarn clean && sh -ac '. ./.env; NODE_ENV=development yarn ts-node node_modules/.bin/webpack'",
    "start": "sh -ac '. ./.env; NODE_ENV=development yarn ts-node node_modules/.bin/webpack serve'",
    "start-console": "./start-console.sh",
    "mock-server:build": "ts-node -O '{\"module\":\"commonjs\"}' mock-server/build.ts",
    "mock-server": "yarn mock-server:build && node mock-server/bootstrap.js",
    "cypress": "cypress open -e TAGS=\"(@core-1 or @core-2 or @ambient or @waypoint or @waypoint-tracing) and not @skip-ossmc\"",
    "cypress:run": "r=0; cypress run --config screenshotsFolder=cypress/screenshots/core -e TAGS=\"(@core-1 or @core-2) and not @skip-ossmc\" || r=1; exit $r",
    "cypress:run:junit": "r=0; cypress run --reporter cypress-multi-reporters --reporter-options configFile=reporter-config.json --config screenshotsFolder=cypress/screenshots/core -e TAGS=\"(@core-1 or @core-2) and not @skip-ossmc\" || r=1; exit $r",
    "cypress:run:test-group:junit": "cypress run --reporter cypress-multi-reporters --reporter-options configFile=reporter-config.json -e TAGS=\"${TEST_GROUP}\"",
    "cypress:run:ambient": "r=0; cypress run --config screenshotsFolder=cypress/screenshots/ambient -e TAGS=\"@ambient and not @skip-ossmc\" || r=1; cypress run --config screenshotsFolder=cypress/screenshots/waypoint -e TAGS=\"@waypoint and not @skip-ossmc\" || r=1; cypress run --config screenshotsFolder=cypress/screenshots/waypoint-tracing -e TAGS=\"@waypoint-tracing and not @skip-ossmc\" || r=1; exit $r",
    "cypress:run:ambient:junit": "r=0; cypress run --reporter cypress-multi-reporters --reporter-options configFile=reporter-config.json --config screenshotsFolder=cypress/screenshots/ambient -e TAGS=\"@ambient and not @skip-ossmc\" || r=1; cypress run --reporter cypress-multi-reporters --reporter-options configFile=reporter-config.json --config screenshotsFolder=cypress/screenshots/waypoint -e TAGS=\"@waypoint and not @skip-ossmc\" || r=1; cypress run --reporter cypress-multi-reporters --reporter-options configFile=reporter-config.json --config screenshotsFolder=cypress/screenshots/waypoint-tracing -e TAGS=\"@waypoint-tracing and not @skip-ossmc\" || r=1; exit $r",
    "cypress:delete:reports": "rm cypress/results/* || true",
    "cypress:combine:reports": "jrm cypress/results/combined-report.xml \"cypress/results/*.xml\"",
    "i18n": "yarn i18n:kiali && yarn i18n:openshift",
    "i18n:kiali": "i18next 'src/kiali/**/*.{ts,tsx}' -o 'src/kiali/locales/$LOCALE/$NAMESPACE.json' -c './i18next-parser.config.ts' --silent",
    "i18n:openshift": "i18next 'src/openshift/**/*.{ts,tsx}' -o 'src/openshift/locales/$LOCALE/$NAMESPACE.json' -c './i18next-parser.config.ts' --silent",
    "ts-node": "yarn i18n && ts-node -O '{\"module\":\"commonjs\"}'",
    "test": "rstest",
    "lint": "eslint src/openshift",
    "lint:gherkin": "gherkin-lint -c .gherkin-lintrc cypress/integration/**/featureFiles/**/*.feature",
    "lint:gherkin:precommit": "if git diff --cached --name-only | grep -E '\\.feature$'; then npm run lint:gherkin; else true; fi",
    "lint:precommit": "if git diff --name-only HEAD | grep -E '\\.tsx?$'; then npm run lint; else true; fi",
    "prettier": "prettier --write \"**/*.{ts,tsx,scss,json}\"",
    "prepare": "cd .. && husky install plugin/.husky",
    "pre-commit": "yarn run pretty-quick --staged --no-restage --bail --pattern ['**/*.{ts,tsx,scss,json}', '!src/kiali'] && npm run lint:precommit && npm run lint:gherkin:precommit"
  },
  "dependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.19.1",
    "@patternfly/chatbot": "^6.5.0",
    "@patternfly/patternfly": "^6.4.0",
    "@patternfly/react-charts": "^8.4.0",
    "@patternfly/react-component-groups": "^6.4.0",
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-drag-drop": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.0",
    "@patternfly/react-topology": "^6.4.0",
    "axios": "^1.17.0",
    "bootstrap-slider-without-jquery": "10.0.0",
    "deep-freeze": "0.0.1",
    "eventemitter3": "4.0.7",
    "i18next": "^23.10.0",
    "i18next-http-backend": "^2.5.0",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.18.0",
    "micro-memoize": "4.0.9",
    "moment": "^2.29.4",
    "monaco-editor": "^0.55.1",
    "react": "^17.0.1",
    "react-ace": "9.1.3",
    "react-copy-to-clipboard": "5.x",
    "react-dom": "^17.0.1",
    "react-flexview": "4.0.3",
    "react-i18next": "^11.7.3",
    "react-redux": "7.2.9",
    "react-resize-detector": "9.1.1",
    "react-router": "5.3.x",
    "react-router-dom": "5.3.x",
    "react-router-dom-v5-compat": "^6.30.3",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtualized": "9.x",
    "redux": "4.0.1",
    "redux-persist": "5.10.0",
    "redux-persist-transform-filter": "^0.0.22",
    "redux-thunk": "2.4.0",
    "regression": "^2.0.1",
    "reselect": "4.0.0",
    "typesafe-actions": "^4.2.1",
    "typestyle": "^2.4.0",
    "victory": "^37.3.6",
    "visibilityjs": "2.0.2"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@eslint/js": "^10.0.1",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.19.0",
    "@rstest/core": "^0.10.3",
    "@svgr/webpack": "^8.1.0",
    "@swc/core": "^1.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/deep-freeze": "^0.1.5",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "4.17.x",
    "@types/node": "^24.0.0",
    "@types/react": "^17.0.1",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "^17.0.1",
    "@types/react-redux": "7.1.7",
    "@types/react-router-dom": "^5.2.0",
    "@types/react-virtualized": "9.x",
    "@types/webpack-dev-server": "^4.5.0",
    "axios-mock-adapter": "^2.1.0",
    "css-loader": "^6.5.1",
    "cypress": "^15.16.0",
    "cypress-multi-reporters": "^2.0.5",
    "esbuild": "^0.27.7",
    "eslint": "^10.5.0",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "express": "^4.21.0",
    "file-loader": "^6.2.0",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "gherkin-lint": "^4.2.4",
    "globals": "^16.2.0",
    "husky": "^8.0.3",
    "i18next-parser": "^9.0.1",
    "jsdom": "^29.1.1",
    "junit-report-merger": "^9.0.4",
    "merge-jsons-webpack-plugin": "^2.0.1",
    "mocha-junit-reporter": "^2.2.1",
    "msw": "^2.12.7",
    "node-polyfill-webpack-plugin": "^2.0.1",
    "prettier": "^2.4.1",
    "pretty-quick": "^3.1.3",
    "sass": "^1.63.6",
    "sass-loader": "^13.3.0",
    "seedrandom": "^3.0.5",
    "style-loader": "^3.3.1",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.4.0",
    "tsconfig-paths-webpack-plugin": "^4.0.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.35.1",
    "webpack": "^5.104.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.1"
  },
  "resolutions": {
    "immutable": "^4.3.8",
    "js-cookie": "^3.0.8",
    "lodash": "^4.18.0",
    "protobufjs": "^7.5.6",
    "react-markdown": "^8.0.7",
    "unist-util-visit-parents": "^5.1.3",
    "webpack": "^5.104.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@4.12.0",
  "browserslist": [
    ">10%",
    "last 2 versions",
    "not dead"
  ],
  "cypress-cucumber-preprocessor": {
    "filterSpecs": true,
    "omitFiltered": true,
    "stepDefinitions": "cypress/integration/**/*.{js,ts}"
  }
}

{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "actions/*": ["./kiali/actions/*"],
      "app/*": ["./kiali/app/*"],
      "components/*": ["./kiali/components/*"],
      "config": ["./kiali/config"],
      "config/*": ["./kiali/config/*"],
      "helpers/*": ["./kiali/helpers/*"],
      "hooks/*": ["./kiali/hooks/*"],
      "i18n": ["./openshift/i18n.ts"],
      "pages/*": ["./kiali/pages/*"],
      "reducers/*": ["./kiali/reducers/*"],
      "routes": ["./kiali/routes.tsx"],
      "routes/*": ["./kiali/routes/*"],
      "services/*": ["./kiali/services/*"],
      "store/*": ["./kiali/store/*"],
      "styles/*": ["./kiali/styles/*"],
      "types/*": ["./kiali/types/*"],
      "utils/*": ["./kiali/utils/*"]
    }
  },
  "exclude": ["node_modules", "build", "coverage", "src/kiali/setupTests.ts", "src/kiali/mocks/**/*"],
  "include": ["src"]
}

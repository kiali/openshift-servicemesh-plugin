######################################################################################
#  Environment variables for the OSSMC plugin.
#
#  These variables are written directly to the resulting JS code and can be
#  used by calling e.g. process.env.API_PROXY
#  They are always strings, so we need to decode them depending on the use case.
#  For development, you need to stop and start the server again in case of changes.
#
######################################################################################

# The ConsolePlugin resource defines a proxy to the internal Kiali Service.
# The OpenShift Console backend proxies these requests to Kiali via BRIDGE_PLUGIN_PROXY (dev)
# or the ConsolePlugin resource proxy config (production).
API_PROXY=/api/proxy/plugin/ossmconsole/kiali

# Prefix added to all CSS classnames to fulfill OpenShift plugin requirements
CSS_PREFIX=ossmconsole_

# I18N namespace to fulfill OpenShift plugin requirements
I18N_NAMESPACE=plugin__ossmconsole

# Let Kiali know if the global scrollbar is enabled or not
GLOBAL_SCROLLBAR=true
